rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // abuse_reports 폴더 (갑질 제보 파일들)
    match /abuse_reports/{fileName} {
      
      // 1. 읽기: 누구나 가능
      allow read: if true;
      
      // 2. 생성: 누구나 가능 (10MB 제한, 멀티미디어 파일 허용)
      allow create: if request.resource.size < 10 * 1024 * 1024
                   && (
                     // 이미지 파일
                     request.resource.contentType.matches('image/.*') ||
                     // 비디오 파일
                     request.resource.contentType.matches('video/.*') ||
                     // 오디오 파일
                     request.resource.contentType.matches('audio/.*')
                   );
      
      // 3. 수정 및 삭제: 절대 불가 (박제 컨셉)
      allow update, delete: if false;
    }
    
    // timeline_data 폴더 (분석 결과 이미지 저장용)
    match /timeline_data/{docId}/{allPaths=**} {
      allow read: if true;
      allow create: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow update, delete: if false;
    }
    
    // 임시 업로드 폴더 (개발용)
    match /temp/{allPaths=**} {
      allow read, write: if true;
    }
  }
}
