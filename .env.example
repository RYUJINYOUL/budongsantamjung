# 로컬: 이 파일을 .env 로 복사한 뒤 값을 채우세요. (.env 는 Git에 올리지 않음)
# Vercel: 아래 변수들을 Project → Settings → Environment Variables 에 등록

# --- AI / 외부 API ---
GEMINI_API_KEY=

# --- 네이버 (지도) ---
NEXT_PUBLIC_NAVER_CLIENT_ID=

# --- 네이버 로그인 (서버 전용) ---
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- 카카오 ---
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=
KAKAO_REST_API_KEY=
# (선택) 카카오 custom token Cloud Function — 미설정 시 yongcar 기본 URL
# KAKAO_AUTH_API_URL=https://asia-northeast3-yongcar-4377c.cloudfunctions.net/kakaoCallback

# --- Firebase (클라이언트 — NEXT_PUBLIC_*) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIRESTORE_DATABASE_ID=

# --- Firebase Admin (서버 전용, 네이버 로그인 필수) ---
# Firebase 콘솔 > 프로젝트 설정 > 서비스 계정 > 새 비공개 키 JSON 전체를 한 줄로
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- 기타 ---
NEXT_PUBLIC_VWORLD_KEY=
NEXT_PUBLIC_TOSS_CLIENT_KEY=
NEXT_PUBLIC_BACKEND_URL=
