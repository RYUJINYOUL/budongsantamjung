rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // 부동산 탐정 정밀 분석 컬렉션 (새로운 기능)
    match /real_estate_analyses/{docId} {
      // 누구나 결과물 조회 가능
      allow read: if true;
      // 생성은 현재 API Route(Client SDK)에서 수행하므로 한시적 허용
      allow create: if true;
      // 수정/삭제는 본인 또는 관리자만 (추후 확장 가능)
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /architectRecruit/{document} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        (request.auth.uid == resource.data.userKey || request.auth.uid == document.split('-')[0]);
    }

    match /recruitAuthoArchi/{document} {
      allow read: if true;
      allow create, update: if request.auth != null;
    }
  
    match /firesale/{document} {
      allow read: if true;
      allow create, update: if request.auth != null;
    }
    
    match /recruitCons/{document} {
      allow read: if true;
      allow create, update: if request.auth != null;
    }
    
    match /applicant/{docId} {
      allow read: if request.auth != null && (
        resource.data.userKey == request.auth.uid || 
        resource.data.proApplyId.split('_')[0] == request.auth.uid ||
        resource.data.proApplyId.split('-')[0] == request.auth.uid ||
        resource.data.professionalsId.split('_')[0] == request.auth.uid ||
        resource.data.professionalsId.split('-')[0] == request.auth.uid
      );
      allow create: if request.auth != null && 
        request.resource.data.userKey == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.userKey == request.auth.uid || 
        resource.data.proApplyId.split('_')[0] == request.auth.uid ||
        resource.data.proApplyId.split('-')[0] == request.auth.uid ||
        resource.data.professionalsId.split('_')[0] == request.auth.uid ||
        resource.data.professionalsId.split('-')[0] == request.auth.uid
      );
      allow delete: if request.auth != null && 
        resource.data.userKey == request.auth.uid;
    }

    match /ad_management/{docId} {
      allow read: if true; 
      allow write: if false; 
    }

    match /proApply/{userId} {
      allow read: if request.auth != null; 
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /applications/{proApplyId} {
      allow read: if true;
      allow write: if request.auth != null;
      match /applicants/{applicantId} {
        allow read: if request.auth != null && (
          resource.data.userKey == request.auth.uid || 
          proApplyId.split('-')[0] == request.auth.uid ||
          proApplyId.split('_')[0] == request.auth.uid
        );
        allow update: if request.auth != null && (
          proApplyId.split('-')[0] == request.auth.uid ||
          proApplyId.split('_')[0] == request.auth.uid ||
          resource.data.userKey == request.auth.uid
        );
        allow create: if request.auth != null;
        allow delete: if request.auth != null && resource.data.userKey == request.auth.uid;
      }
    }
    
    match /users/{userId} {
      allow read: if request.auth != null; 
      allow write: if request.auth != null && request.auth.uid == userId;
      match /private_info/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /push/{pushId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    match /professionals/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        (request.auth.uid == resource.data.userKey || 
         request.auth.uid == docId.split('-')[0]);
    }
    
    match /proApply/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        (request.auth.uid == resource.data.userKey || 
         request.auth.uid == docId.split('-')[0]);
      match /quotations/{quotationId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && 
          request.auth.uid == resource.data.uid;
      }
    }
    
    match /construction/{docId} {
      allow read: if true; 
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        (request.auth.uid == resource.data.userKey || 
         request.auth.uid == docId.split('-')[0]);
    }
    
    match /conApply/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        (request.auth.uid == resource.data.userKey || 
         request.auth.uid == docId.split('-')[0]);
      match /quotations/{quotationId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null;
      }
    }
    
    match /equipment/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        (request.auth.uid == resource.data.userKey || 
         request.auth.uid == docId.split('-')[0]);
    }
    
    match /equipApply/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        (request.auth.uid == resource.data.userKey || 
         request.auth.uid == docId.split('-')[0]);
      match /quotations/{quotationId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && 
          request.auth.uid == resource.data.uid;
      }
    }
    
    match /apply/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        (request.auth.uid == resource.data.userId || 
         request.auth.uid == resource.data.userKey ||
         request.auth.uid == docId.split('-')[0]);
    }

    match /community/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorId;
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;
      }
    }
    
    match /notifications/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
